<Window x:Class="AgentMux.Win.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AgentMux Windows"
        Width="1120"
        Height="720"
        MinWidth="860"
        MinHeight="540"
        Background="{StaticResource AgentMuxBackground}"
        Foreground="{StaticResource AgentMuxText}"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource AgentMuxPanel}"
                BorderBrush="{StaticResource AgentMuxBorder}"
                BorderThickness="0,0,1,0">
            <DockPanel Margin="14">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                    <TextBlock Text="AgentMux"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Pre-alpha Windows scaffold"
                               Foreground="{StaticResource AgentMuxMutedText}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
                    <Button Content="New workspace"
                            Height="34"
                            Click="NewWorkspace_Click" />
                    <Button Content="Test notification"
                            Height="34"
                            Margin="0,8,0,0"
                            Click="TestNotification_Click" />
                </StackPanel>

                <ListBox x:Name="WorkspaceList"
                         DisplayMemberPath="Title"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource AgentMuxText}"
                         SelectionChanged="WorkspaceList_SelectionChanged" />
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock x:Name="WorkspaceTitle"
                           FontSize="26"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="WorkspaceMeta"
                           Foreground="{StaticResource AgentMuxMutedText}"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Row="1"
                    Background="#080A0F"
                    BorderBrush="{StaticResource AgentMuxBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="18">
                <StackPanel>
                    <TextBlock Text="Terminal renderer placeholder"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Next sprint wires ConPTY output into the WebView2/xterm terminal host."
                               Foreground="{StaticResource AgentMuxMutedText}"
                               Margin="0,8,0,0" />
                    <TextBox x:Name="ScreenPreview"
                             Margin="0,18,0,0"
                             Background="#0F131A"
                             Foreground="{StaticResource AgentMuxText}"
                             BorderBrush="{StaticResource AgentMuxBorder}"
                             FontFamily="Consolas"
                             FontSize="14"
                             MinHeight="220"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             IsReadOnly="True" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="PipeStatus"
                       Grid.Row="2"
                       Foreground="{StaticResource AgentMuxMutedText}"
                       Margin="0,12,0,0" />
        </Grid>
    </Grid>
</Window>
